# ── Discord ────────────────────────────────────────────────────────────────────
# Bot token — discord.com/developers/applications → Bot → Reset Token  [REQUIRED]
DISCORD_BOT_TOKEN=

# Server ID — optional. Set for instant slash command rollout (dev).
# Leave empty to register globally (~1h propagation).
DISCORD_GUILD_ID=

# ── AI — OpenAI-compatible API (fallback if providers.yaml is not present) ────
# Copy providers.example.yaml → providers.yaml for multi-provider + fallback chain.
# These .env settings are used only when providers.yaml does not exist.

# API key for your chosen provider.
OPENAI_API_KEY=

# Model name passed to the API. Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Base URL of the OpenAI-compatible endpoint. Leave empty for OpenAI default.
# Examples:
#   Ollama:    http://localhost:11434/v1
#   Groq:      https://api.groq.com/openai/v1
#   LM Studio: http://localhost:1234/v1
OPENAI_BASE_URL=

# ── Access Control ────────────────────────────────────────────────────────────
# Comma-separated Discord user IDs allowed to use this bot.
# Leave empty to allow everyone.
# Get your ID: Discord → Settings → Advanced → Developer Mode → right-click yourself → Copy User ID
CONDUCTOR_ALLOWED_USERS=

# ── Storage (optional overrides) ──────────────────────────────────────────────
# All state is stored as plain files under ./data/ (gitignored by default).

# Long-term memory file (persists across all sessions, loaded into every conversation)
MEMORY_PATH=./data/memory/MEMORY.md

# Per-session conversation context files
CONTEXTS_PATH=./data/contexts

# Per-topic metadata files
TOPICS_PATH=./data/topics

# ── OpenClaw (optional) ────────────────────────────────────────────────────────
# Override only if OpenClaw is NOT installed at the default location (~/.openclaw).
OPENCLAW_ROOT=
